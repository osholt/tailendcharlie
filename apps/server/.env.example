RIDE_RELAY_ENVIRONMENT=production
RIDE_RELAY_DATABASE_URL=postgresql+psycopg://ride_relay:replace-me@db:5432/ride_relay
RIDE_RELAY_DATA_ENCRYPTION_KEY=replace-with-base64url-32-byte-key
RIDE_RELAY_CURSOR_SIGNING_KEY=replace-with-another-base64url-32-byte-key
RIDE_RELAY_TRUSTED_HOSTS=["relay.example.com","127.0.0.1","localhost"]
RIDE_RELAY_FORWARDED_ALLOW_IPS=127.0.0.1
RIDE_RELAY_RIDE_RETENTION_HOURS=72
RIDE_RELAY_ENDED_RIDE_GRACE_HOURS=24
RIDE_RELAY_JOIN_CODE_LOOKUP_RATE_LIMIT_REQUESTS=30
RIDE_RELAY_JOIN_CODE_LOOKUP_RATE_LIMIT_WINDOW_SECONDS=60
RIDE_RELAY_DISCOVERY_SUGGESTION_RATE_LIMIT_REQUESTS=10
RIDE_RELAY_DISCOVERY_SUGGESTION_RATE_LIMIT_WINDOW_SECONDS=3600
# Optional; set to a generated 32+ character secret to enable moderation APIs.
RIDE_RELAY_DISCOVERY_ADMIN_TOKEN=
RIDE_RELAY_DISCOVERY_ADMIN_NAME=discovery-admin
RIDE_RELAY_DISCOVERY_REJECTED_RETENTION_DAYS=90
RIDE_RELAY_DISCOVERY_ALLOWED_ORIGINS=["https://tailendcharlie.app","https://www.tailendcharlie.app"]
RIDE_RELAY_MAXIMUM_ACTIVE_RIDES=100
RIDE_RELAY_MAXIMUM_EVENTS_PER_RIDE=5000
RIDE_RELAY_MAXIMUM_STORED_BYTES_PER_RIDE=26214400
RIDE_RELAY_MAXIMUM_REPLAYS_PER_RIDE=5000
RIDE_RELAY_MAXIMUM_REPLAY_BYTES_PER_RIDE=26214400
RIDE_RELAY_PRE_START_PRESENCE_TTL_SECONDS=45
RIDE_RELAY_MAXIMUM_PRE_START_PRESENCE_RIDERS=200
RIDE_RELAY_OBSERVER_READ_RATE_LIMIT_REQUESTS=120
RIDE_RELAY_OBSERVER_READ_RATE_LIMIT_WINDOW_SECONDS=60
RIDE_RELAY_OBSERVER_IP_ABUSE_RATE_LIMIT_REQUESTS=5000
RIDE_RELAY_OBSERVER_CREATE_RATE_LIMIT_REQUESTS=10
RIDE_RELAY_OBSERVER_CREATE_IP_ABUSE_RATE_LIMIT_REQUESTS=500
RIDE_RELAY_OBSERVER_CREATE_RATE_LIMIT_WINDOW_SECONDS=3600
RIDE_RELAY_MAXIMUM_OBSERVER_GRANTS_PER_RIDE=50
RIDE_RELAY_PROTOCOL_VERSION=1
RIDE_RELAY_MINIMUM_CLIENT_PROTOCOL=1
RIDE_RELAY_SUPPORTED_CAPABILITIES=["ride-start-v1","membership-v1","route-revisions-v1","pre-start-presence-v1","push-notifications-v1","observer-access-v1"]
RIDE_RELAY_REQUIRED_CAPABILITIES=[]
RIDE_RELAY_COMPATIBILITY_CACHE_SECONDS=300
RIDE_RELAY_UPDATE_URL=https://tailendcharlie.app
RIDE_RELAY_IOS_UPDATE_URL=https://tailendcharlie.app
RIDE_RELAY_ANDROID_UPDATE_URL=https://tailendcharlie.app
# Optional push providers. Private keys are base64-encoded PEM values and
# belong only in the deployment environment or secret manager.
RIDE_RELAY_APNS_TEAM_ID=
RIDE_RELAY_APNS_KEY_ID=
RIDE_RELAY_APNS_BUNDLE_ID=
RIDE_RELAY_APNS_PRIVATE_KEY_BASE64=
RIDE_RELAY_APNS_SANDBOX=false
RIDE_RELAY_FCM_PROJECT_ID=
RIDE_RELAY_FCM_CLIENT_EMAIL=
RIDE_RELAY_FCM_PRIVATE_KEY_BASE64=
RIDE_RELAY_PUSH_DELIVERY_TIMEOUT_SECONDS=8
